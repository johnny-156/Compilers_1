	public void visit(MethName methName) {
		methodObj = Helper.getObj(methName.getName());
		
		if (methodObj.getName().equals("main") && namespaceObj == null) { //ako je metoda naziva main(), ali nije u nekom namespace, vec globalna
			mainPc = Code.pc;												//dodela vrednosti mainPc
		}	
		methodObj.setAdr(Code.pc); //postavljena adresa za metodu, samo sto nije vidljiva, tj pre se pozove dump od ovog, pa se ne vidi, ali u pozadini radi
		
		//instrukcija enter, koja nakon zahteva 2 argumenta, prvi broj formalnih, a drugi formalni + lokalni(koristio sam FpPos polje)
		Code.put(Code.enter);
		Code.put(methodObj.getLevel());
		Code.put(methodObj.getLevel() + methodObj.getFpPos());
	}	
	
	public void visit(MethodDecl methodDecl) {
		methodObj = null;						//ponistavanje promenljive
		Code.put(Code.exit);					//dve suprotne operacije od call i enter
		Code.put(Code.return_);
	}
