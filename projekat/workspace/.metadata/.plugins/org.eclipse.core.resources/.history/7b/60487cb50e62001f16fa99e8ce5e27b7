	public void visit(DesignatorEqual destEqual) {
		ExprVisitor visitor1 = new ExprVisitor();
		visitor1.setErrorOccurredObject(error);
		destEqual.getExpr().traverseBottomUp(visitor1);
		
		StatementReadDesignatorVisitor visitor2 = new StatementReadDesignatorVisitor();
		visitor2.setErrorOccurredObject(error);
		destEqual.getDesignator().traverseBottomUp(visitor2);
		
		visitor2.readStore(visitor2.symbol);
	}
	
	public void visit(DesignatorIncrement destInc) {
		ExprVisitor visitor = new ExprVisitor();
		visitor.setErrorOccurredObject(error);
		destInc.getDesignator().traverseBottomUp(visitor);
		
		Code.put(Code.const_1);
		Code.put(Code.add);

		StatementReadDesignatorVisitor visitor2 = new StatementReadDesignatorVisitor();
		visitor2.setErrorOccurredObject(error);
		destInc.getDesignator().traverseBottomUp(visitor2);
		
		visitor2.readStore(visitor2.symbol);
	}
	
	public void visit(DesignatorDecrement destDec) {
		ExprVisitor visitor = new ExprVisitor();
		visitor.setErrorOccurredObject(error);
		destDec.getDesignator().traverseBottomUp(visitor);
		
		Code.put(Code.const_1);
		Code.put(Code.sub);

		StatementReadDesignatorVisitor visitor2 = new StatementReadDesignatorVisitor();
		visitor2.setErrorOccurredObject(error);
		destDec.getDesignator().traverseBottomUp(visitor2);
		
		visitor2.readStore(visitor2.symbol);
	}
