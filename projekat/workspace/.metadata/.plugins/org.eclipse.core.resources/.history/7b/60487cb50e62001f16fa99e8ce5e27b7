	public void visit(StatementRead stmtRead) { //sadrzaj je:(adr, index(samo za niz)), pa vrednost, treba read pre svega da se uradi
		StatementReadDesignatorVisitor visitor = new StatementReadDesignatorVisitor(); //obidjemo designator, stavljamo sta treba da bude na steku pre vrednosti
		visitor.setErrorOccurredObject(error);
		visitor.shouldLoadMatrixElement = false;
		stmtRead.getDesignator().traverseBottomUp(visitor);
		
		Obj exprObj = visitor.symbol;
		if (exprObj != null) { //da se zastitimo od one null reference
			Struct type = exprObj.getType();
			
			if (type.getKind() == Struct.Char || type.getKind() == Struct.Bool) { //ako je tip char ili bool, onda pozivamo bread, ovde ucitamo val na stek
				Code.put(Code.bread);
			} else {
				Code.put(Code.read);
			}
			
			if(exprObj.getType().getKind() == Struct.Array) { //ako je niz imamo adr, index, value
				Code.put(Code.dup_x2);
				Code.put(Code.pop);
			}
			
			if (exprObj.getType().getKind() == Struct.Enum) { // ako je matrica
				if (exprObj.getType().getElemType().getKind() == Struct.Int) {
					Code.put(Code.read);
				} else {
					Code.put(Code.bread);
				}
			}
			
//			temp = read (t|f)
//					if (temp == 't' || temp == 'T') {
//						bt = 1;
//					} else {
//						bt = 0;
//					}
//-------------------------------------------------------
//					read			temp
//					dup			temp temp
//
//					const_ 116(t)		temp temp 116
//					jne drugiDeoIfa		temp
//					pop			/
//					jmp trueDeo
//
//					drugiDeoIfa:
//					const_ 84(T)		temp 84
//					jne else		/
//
//					trueDeo:
//					const_1			1
//					jmp nastavak
//
//					else: const_0		0
//
//					nastavak: store 1	/
			
			if (exprObj.getType().getKind() == Struct.Bool || 
					exprObj.getType().getKind() == Struct.Enum && exprObj.getType().getElemType().getKind() == Struct.Bool ||
					exprObj.getType().getKind() == Struct.Array && exprObj.getType().getElemType().getKind() == Struct.Bool) {
				//dupliranje zbog poredjenja
				Code.put(Code.dup);
				Code.loadConst(116);
				//moguci skok na DrugiDeoIfa
				Code.put(Code.jcc + Code.ne);
				int patchAdrDrugiDeoIfa = Code.pc;
				Code.put2(0);
				//nakon prolaza prvog uslova, ispada jedan viska, koji je trebao za eventualno novo poredjenje
				Code.put(Code.pop);	
				//skok na trueDeo
				Code.put(Code.jmp);
				int patchJumpTrueDeo = Code.pc;
				Code.put2(0);
				
				//ovde pocinje DrugiDeoIfa
				Code.fixup(patchAdrDrugiDeoIfa);
				Code.loadConst(84);			
				//moguci skok na else
				Code.put(Code.jcc + Code.ne);
				int patchAdrElse = Code.pc;
				Code.put2(0);
				
				//ovde pocinje TrueDeo
				Code.fixup(patchJumpTrueDeo);
				Code.loadConst(1);
				//skok na nastavak
				Code.put(Code.jmp);
				int patchAdrNastavak = Code.pc;
				Code.put2(0);
				
				//ovde pocinje Else
				Code.fixup(patchAdrElse);
				Code.loadConst(0);
				
				//ovde pocinje Nastavak
				Code.fixup(patchAdrNastavak);	
			}
			
			visitor.readStore(exprObj); //ovde pozivamo krajnje instrukcije, za sve ono sto je do tada na steku
		}
	}
