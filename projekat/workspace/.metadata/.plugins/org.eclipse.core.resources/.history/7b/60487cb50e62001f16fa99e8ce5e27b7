	public void visit(StatementPrintSimple ps) {
		ExprVisitor visitor = new ExprVisitor(); //ucitavanje vrednosti
		visitor.setErrorOccurredObject(error);
		ps.getExpr().traverseBottomUp(visitor);

		generatePrintInstructions(visitor, 0);		
	}
	
	public void visit(StatementPrintExpanded e) {
		ExprVisitor visitor = new ExprVisitor();
		visitor.setErrorOccurredObject(error);
		e.getExpr().traverseBottomUp(visitor);
		int number = e.getNumConst().getNumber().intValue(); //sada vec ono sto je uneo korisnik stavljamo na stek
		
		generatePrintInstructions(visitor, number);
		
	}
	
	public void generatePrintInstructions(ExprVisitor visitor, int number) {
		if (visitor.isBoolFactor) { 					//ispisivanje bool vrednosti, konkretne
			if (visitor.boolFactorValue) {				//tip designatora je bool
				Helper.addInstructionsForPrintingString("true", number);
			} else {
				Helper.addInstructionsForPrintingString("false", number);
			}			
		} else if (visitor.isCharFactor) { //ispisivanje char vrednosti, konkretne
			
			Code.loadConst(number); //stavljamo konkretan broj na stek za sirinu
			Code.put(Code.bprint);
			
		} else { //ispisivanje designatora, koji moze biti opet tipa char ili bool ili int
			if (visitor.isBooleanType) {
				
//				load			1
//				const_0			1 0
//				jeq falseBlock
//
//				trueBlock:
//					const_ t		t
//					const_			t 0
//				bprint			/
//				jmp nastavak
//
//
//				falseBlock:
//					const_ t		t
//					const_			t 0
//					bprint			/
//				nastavak:
				
				Code.loadConst(0);
				//jeq falseBlock
				Code.put(Code.jcc + Code.eq);
				int patchAddrFalseBlock = Code.pc;
				Code.put2(0);
			
				//ulazi u true opciju i ide na slanje 
				Helper.addInstructionsForPrintingString("true", number);	
				//jmp nastavak
				Code.put(Code.jmp);
				int patchAdrNastavak = Code.pc;
				Code.put2(0);
				
				//ovde pocinje falseBlock
				Code.fixup(patchAddrFalseBlock);
				//ulazi u false opciju i ide na slanje
				Helper.addInstructionsForPrintingString("false", number);	
				//ovde pocinje Nastavak
				Code.fixup(patchAdrNastavak);		
				
			} else if (visitor.isCharType) {
				Code.loadConst(number); //stavljamo konkretan broj na stek za sirinu
				Code.put(Code.bprint);
			} else {
				Code.loadConst(number); //stavljamo konkretan broj na stek za sirinu
				Code.put(Code.print);				
			}
			
		}		
	}
