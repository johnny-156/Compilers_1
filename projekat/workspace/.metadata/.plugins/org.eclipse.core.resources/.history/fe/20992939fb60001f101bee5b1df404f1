	public void visit(StatementRead stmtRead) {
		ValidExprVisitor visitor = new ValidExprVisitor();
		visitor.setErrorOccurredObject(error);
		stmtRead.getDesignator().traverseBottomUp(visitor);
		
    	if (!visitor.validity) {
    		return;
		}
    	
    	boolean foundWrong = false;
    	
    	if (visitor.exprType.getKind() == Struct.Array || visitor.exprType.getKind() == Struct.Enum) { //ako je kolekcija
    		if(visitor.exprType.getElemType() != Tab.intType && visitor.exprType.getElemType() != Tab.charType && visitor.exprType.getElemType().getKind() != Struct.Bool) { //neodgovarajuci tip
    			foundWrong = true;
    		} else { //ako je normalnog tipa unutar kolekcije, pa proverimo na referencu
    			
    			Designator d = stmtRead.getDesignator();
    	    	DesignatorArray da = d.getDesignatorArray();  
    	    	if(visitor.exprType.getKind() == Struct.Array && da instanceof NoDesignatorArray) foundWrong = true;
    	    	if(visitor.exprType.getKind() == Struct.Enum && da instanceof NoDesignatorArray) foundWrong = true;
    			
    		}
		} else { //kada nije kolekcija
			if(visitor.exprType != Tab.intType && visitor.exprType != Tab.charType && visitor.exprType.getKind() != Struct.Bool) { //neodgovarajuci tip
    			foundWrong = true;
			}
		}
	    	
    	if(visitor.exprObj.getKind() == Obj.Con) foundWrong = true; //konstanta ne moze biti u read()
    	
    	if(foundWrong) {
    		report_error("Izraz koji zelimo da ucitamo je neodgovarajuceg tipa ili je referenca ili je konstanta!", stmtRead);
    	}
	}
	
