	public void visit(StatementPrintExpanded printExpanded) {
		ValidExprVisitor visitor = new ValidExprVisitor();
    	visitor.setErrorOccurredObject(error);
    	printExpanded.getExpr().traverseBottomUp(visitor);
    	
    	if (!visitor.validity) {
    		return;
    	}
    	
    	int number = printExpanded.getNumConst().getNumber().intValue();
    	NumConst defaultValue = new NumConst(0);
    	defaultValue.setParent(printExpanded); //da bi  bili sigurni da smo promenili vrednost roditelja
    	if(number < 0) {
    		report_info("Unesena vrednost se ne smatra validnom i u kodu ce se podrazumevati nula umesto nje!", printExpanded.getNumConst());
    		printExpanded.setNumConst(defaultValue);
    	}
    	
    	if(visitor.exprType != Tab.intType && visitor.exprType != Tab.charType && visitor.exprType.getKind() != Struct.Bool) {
    		report_error("Ono sto se ispise nije ni int, ni char, ni bool tipa!", printExpanded.getNumConst());
    	}
	}
