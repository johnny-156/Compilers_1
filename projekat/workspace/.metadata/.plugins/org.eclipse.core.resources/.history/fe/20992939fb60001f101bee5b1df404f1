	public void visit(DesignatorEqual destEqual) {
		ValidExprVisitor visitor1 = new ValidExprVisitor();
    	visitor1.setErrorOccurredObject(error);
    	destEqual.getDesignator().traverseBottomUp(visitor1);
    	
		if (!visitor1.validity) {
			return;
		}
    	
		ValidExprVisitor visitor2 = new ValidExprVisitor();
    	visitor2.setErrorOccurredObject(error);
    	destEqual.getExpr().traverseBottomUp(visitor2);
		
		if (!visitor2.validity) {
    		return;
    	}
    	
		if(visitor2.exprType != Tab.nullType) { //mora se dodeljivati nesto sto je nenulto, u suprotnom nema smisla
			if(visitor1.exprType.getKind() != visitor2.exprType.getKind()) {
				report_error("U izrazu dodele vrednosti nemamo kompatibilne tipove po dodeli!", destEqual);
			} else { //ovde su sigurno jednaki
				if(visitor1.exprType.getKind() == Struct.Array || visitor1.exprType.getKind() == Struct.Enum) {
					if(visitor1.exprType.getElemType().getKind() != visitor2.exprType.getElemType().getKind()) {
						report_error("U izrazu dodele vrednosti nemamo kompatibilne tipove po dodeli!", destEqual);
					}
				}
			}
		}
	}
	
	public void visit(DesignatorIncrement destInc) {
		ValidExprVisitor visitor = new ValidExprVisitor();
    	visitor.setErrorOccurredObject(error);
    	destInc.getDesignator().traverseBottomUp(visitor);
    	
    	if (!visitor.validity) {
    		return;
    	}
    	
    	boolean foundWrong = false;
    	if (visitor.exprType.getKind() == Struct.Array || visitor.exprType.getKind() == Struct.Enum) {
    		if(visitor.exprType.getElemType().getKind() != Struct.Int) {
    			foundWrong = true;
			}
		} else {
			if(visitor.exprType.getKind() != Struct.Int) {
    			foundWrong = true;
			}
		}
    	
    	if(visitor.exprObj.getKind() == Obj.Con) foundWrong = true;
    	
    	Designator d = destInc.getDesignator();
    	DesignatorArray da = d.getDesignatorArray();  
    	if(visitor.exprType.getKind() == Struct.Array && da instanceof NoDesignatorArray) foundWrong = true;
    	if(visitor.exprType.getKind() == Struct.Enum && da instanceof NoDesignatorArray) foundWrong = true;
    	
    	if(foundWrong) {
    		report_error("Izraz koji zelimo da inkrementiramo nije int tip ili je referenca ili je konstanta!", destInc);
    	}
	}
	
