package rs.ac.bg.etf.pp1;

import rs.ac.bg.etf.pp1.ast.*;
import rs.etf.pp1.symboltable.*;
import rs.etf.pp1.symboltable.concepts.*;

public class StatementVisitor extends MyVisitor {
	
	public boolean returnFound;
	public Obj returnType;
	
	public String MethName;
	
	public void visit(DesignatorEqual destEqual) {
		ValidExprVisitor visitor1 = new ValidExprVisitor();
    	visitor1.setErrorOccurredObject(error);
    	destEqual.getDesignator().traverseBottomUp(visitor1);
    	
		if (!visitor1.validity) {
			return;
		}
    	
		ValidExprVisitor visitor2 = new ValidExprVisitor();
    	visitor2.setErrorOccurredObject(error);
    	destEqual.getExpr().traverseBottomUp(visitor2);
		
		if (!visitor2.validity) {
    		return;
    	}
    	
		if(visitor2.exprType != Tab.nullType) { //mora se dodeljivati nesto sto je nenulto, u suprotnom nema smisla
			if(visitor1.exprType.getKind() != visitor2.exprType.getKind()) {
				report_error("U izrazu dodele vrednosti nemamo kompatibilne tipove po dodeli!", destEqual);
			} else { //ovde su sigurno jednaki
				if(visitor1.exprType.getKind() == Struct.Array || visitor1.exprType.getKind() == Struct.Enum) {
					if(visitor1.exprType.getElemType().getKind() != visitor2.exprType.getElemType().getKind()) {
						report_error("U izrazu dodele vrednosti nemamo kompatibilne tipove po dodeli!", destEqual);
					}
				}
			}
		}
	}
	
	public void visit(DesignatorIncrement destInc) {
		ValidExprVisitor visitor = new ValidExprVisitor();
    	visitor.setErrorOccurredObject(error);
    	destInc.getDesignator().traverseBottomUp(visitor);
    	
    	if (!visitor.validity) {
    		return;
    	}
    	
    	boolean foundWrong = false;
    	if (visitor.exprType.getKind() == Struct.Array || visitor.exprType.getKind() == Struct.Enum) {
    		if(visitor.exprType.getElemType().getKind() != Struct.Int) {
    			foundWrong = true;
			}
		} else {
			if(visitor.exprType.getKind() != Struct.Int) {
    			foundWrong = true;
			}
		}
    	
    	if(foundWrong) {
    		report_error("Izraz koji zelimo da inkrementiramo nije tipa int!", destInc);
    	}
	}
	
	public void visit(DesignatorDecrement destDec) {
		ValidExprVisitor visitor = new ValidExprVisitor();
    	visitor.setErrorOccurredObject(error);
    	destDec.getDesignator().traverseBottomUp(visitor);
		
		if (!visitor.validity) {
    		return;
    	}
    	
    	boolean foundWrong = false;
    	if (visitor.exprType.getKind() == Struct.Array || visitor.exprType.getKind() == Struct.Enum) {
    		if(visitor.exprType.getElemType().getKind() != Struct.Int) {
    			foundWrong = true;
			}
		} else {
			if(visitor.exprType.getKind() != Struct.Int) {
    			foundWrong = true;
			}
		}
    	
    	if(foundWrong) {
    		report_error("Izraz koji zelimo da dekrementiramo nije tipa int!", destDec);
    	}
	}
	
	public void visit(StatementFuncCall destFuncCall) {
		StatementFuncCallVisitor visitor = new StatementFuncCallVisitor();
		visitor.setErrorOccurredObject(error);
		destFuncCall.traverseBottomUp(visitor);
	}
	
	public void visit(StatementRead stmtRead) {
		ValidExprVisitor visitor = new ValidExprVisitor();
		visitor.setErrorOccurredObject(error);
		stmtRead.getDesignator().traverseBottomUp(visitor);
		
    	if (!visitor.validity) {
    		return;
		}
	
		if(visitor.exprType != Tab.intType && visitor.exprType != Tab.charType && visitor.exprType.getKind() != Struct.Bool) {
			report_error("Ono sto se ucitava nije ni int, ni char, ni bool tipa!", stmtRead);
		}
	}
	
	public void visit(StatementPrintSimple printSimple) {
		ValidExprVisitor visitor = new ValidExprVisitor();
    	visitor.setErrorOccurredObject(error);
    	printSimple.getExpr().traverseBottomUp(visitor);
    	
    	if (!visitor.validity) {
    		return;
    	}
    	
    	if(visitor.exprType != Tab.intType && visitor.exprType != Tab.charType && visitor.exprType.getKind() != Struct.Bool) {
    		report_error("Ono sto se ispise nije ni int, ni char, ni bool tipa!", printSimple.getExpr().getExprWhole());
    	}
	}
	
	public void visit(StatementPrintExpanded printExpanded) {
		ValidExprVisitor visitor = new ValidExprVisitor();
    	visitor.setErrorOccurredObject(error);
    	printExpanded.getExpr().traverseBottomUp(visitor);
    	
    	if (!visitor.validity) {
    		return;
    	}
    	
    	int number = printExpanded.getNumConst().getNumber().intValue();
    	NumConst defaultValue = new NumConst(0);
    	defaultValue.setParent(printExpanded); //da bi  bili sigurni da smo promenili vrednost roditelja
    	if(number < 0) {
    		report_info("Unesena vrednost se ne smatra validnom i u kodu ce se podrazumevati nula umesto nje!", printExpanded.getNumConst());
    		printExpanded.setNumConst(defaultValue);
    	}
    	
    	if(visitor.exprType != Tab.intType && visitor.exprType != Tab.charType && visitor.exprType.getKind() != Struct.Bool) {
    		report_error("Ono sto se ispise nije ni int, ni char, ni bool tipa!", printExpanded.getNumConst());
    	}
	}
}
